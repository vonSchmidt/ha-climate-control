#!/usr/bin/env bash
set -euo pipefail

echo "==> ruff lint"
python -m ruff check custom_components/ tests/

echo "==> ruff format"
python -m ruff format --check custom_components/ tests/

echo "==> mypy"
python -m mypy custom_components/

echo "==> pytest"
python -m pytest tests/ -v

echo "All checks passed."
